{
  "name": "wave-interface",
  "private": true,
  "version": "0.1.0",
  "description": "Wave interface service: Next.js web UI, Telegram bot, Google and Telegram auth.",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:web": "bun --filter @wave/web dev",
    "dev:bot": "bun --filter @wave/bot dev",
    "build": "bun --filter \"*\" build",
    "lint": "bun --filter \"*\" lint",
    "typecheck": "bun --filter \"*\" typecheck",
    "db:up": "docker compose up -d mongodb",
    "db:down": "docker compose down"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5.6.3"
  },
  "engines": {
    "bun": ">=1.1.0"
  },
  "packageManager": "bun@1.3.13"
}
