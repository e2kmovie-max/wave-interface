# ---------------------------------------------------------------------------
# Wave interface — example environment.
#
#   cp .env.example .env  # then fill in real values
#
# Notes:
#   * APP_SECRET signs session cookies and the /tg-auth deeplink token. Use a
#     strong random value in production (>=32 bytes of entropy).
#   * GOOGLE_* credentials come from
#     https://console.cloud.google.com/apis/credentials → "OAuth 2.0 Client IDs".
#     Authorized redirect URI must be PUBLIC_WEB_URL + /api/auth/google/callback.
#   * BOT_TOKEN comes from @BotFather. BOT_USERNAME is the bot's @username
#     (no leading "@"). Required for both the Telegram Mini App and the
#     /tg-auth deeplink notifications.
# ---------------------------------------------------------------------------

# Connection string for MongoDB. Defaults to the docker-compose service.
MONGODB_URI=mongodb://wave:wave@localhost:27017/wave?authSource=admin

# Secret used for HMAC signatures (sessions, deeplink tokens, OAuth state).
# Generate with: openssl rand -hex 32
APP_SECRET=dev-only-app-secret-replace-me-please

# Public URL the web app is served at. Used to build Google OAuth redirect
# URIs and the /tg-auth deeplink. No trailing slash.
PUBLIC_WEB_URL=http://localhost:3000

# Google OAuth 2.0 Client (web application). The redirect URI you configure
# in Google Cloud Console must match: <PUBLIC_WEB_URL>/api/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Telegram bot credentials.
BOT_TOKEN=
BOT_USERNAME=

# Comma-separated Telegram user ids granted access to the in-bot admin panel.
ADMIN_TELEGRAM_IDS=

# Comma-separated Google account emails granted access to the web admin panel.
ADMIN_GOOGLE_EMAILS=

# Optional: JSON array of streaming instances to upsert on master startup.
# Example: [{"name":"local","url":"http://localhost:8080","secret":"..."}]
INSTANCES_JSON=

# Health-check cadence for streaming instances.
INSTANCE_HEALTH_INTERVAL_SECONDS=15
INSTANCE_HEALTH_TIMEOUT_MS=5000
